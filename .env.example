# Environment variables template for Siddhant AI Persona Platform
# Copy to .env and fill in the secrets

# Network config
HOST=127.0.0.1
PORT=8000

# GitHub Settings
GITHUB_PAT=your_github_personal_access_token_here
GITHUB_USERNAME=Siddhant

# OpenRouter Settings (used for Persona Profile generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Directory for indexes and data storage
DATA_DIR=data
